# Copy to .env and fill in real values. .env is gitignored.
# Production secrets are injected via AWS Secrets Manager — do not
# commit this file with real values.

# Postgres connection. Phase 5D.2 split:
#   DATABASE_URL — runtime app connection, runs as `riskd_app_login`
#     (LOGIN INHERIT; receives riskd_app's grants). RLS enforces under
#     this role; the postgres superuser is NOT used at runtime.
#   ALEMBIC_DATABASE_URL — migration connection, runs as the postgres
#     superuser (or any role with CREATE/ALTER privileges). Alembic
#     cannot run schema DDL as `riskd_app_login` because that role
#     lacks the necessary catalog grants.
# host-side commands (pytest from host) use `localhost`; the
# compose-up form uses the service hostname `postgres`.
DATABASE_URL=postgresql://riskd_app_login:riskd_app_login_dev@postgres:5432/riskd
ALEMBIC_DATABASE_URL=postgresql://riskd:riskd@postgres:5432/riskd

# Postgres image bootstrap (read by the postgres container on first
# startup; ignored thereafter unless the volume is recreated).
POSTGRES_USER=riskd
POSTGRES_PASSWORD=riskd
POSTGRES_DB=riskd

# HMAC secret for PII hashing at ingress. 32+ bytes random in prod;
# rotation requires baseline-store cold period (HMAC keys are not
# portable across rotations).
HMAC_SECRET=dev-only-do-not-use-in-prod-32-bytes-min

# API token prefix (informational; tokens are hashed via SHA-256
# before storage in api_tokens.token_hash).
API_TOKEN_PREFIX=rsk_

# IP enrichment data-source secrets. Free signup at the respective
# providers; production values land in AWS Secrets Manager.
# MaxMind: https://www.maxmind.com/en/geolite2/signup
MAXMIND_LICENSE_KEY=
# IP2Proxy LITE PX11: https://lite.ip2location.com/
IP2PROXY_DOWNLOAD_TOKEN=

# Local directory where scripts/fetch_enrichment.py writes source
# files (mounted as a volume in production).
ENRICHMENT_DATA_DIR=/app/data/enrichment

# Application log level (DEBUG | INFO | WARNING | ERROR).
LOG_LEVEL=INFO

# Auth toggle. `true` in any non-local environment. `false` is the
# intended local dev behavior (security-auditor carve-out per
# .claude/agents/security-auditor.md).
AUTH_ENABLED=true

# Deployment environment. `development` / `dev` / `local` exposes the
# interactive API docs (/docs, /redoc, /openapi.json); any other value
# (including unset) disables them. Fail-closed default is production.
ENVIRONMENT=development
