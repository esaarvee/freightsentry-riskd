# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Editor/IDE
.idea/
./.venv
.vscode/

values-dev.yaml

/services/gateway/fraud_gateway.egg-info/
/libs/shared/fraud_shared.egg-info/
__pycache__/
*.pyc
*.pyo
*.pyd
*.py-e
*.egg-info/
dist/
build/
*.egg

.vscode/launch.json

local-dev/postman/results/

# Seed data and test data with real customer/enterprise IDs — never commit
local-dev/scripts/pg-seed.sql
local-dev/scripts/mysql-init.sql
local-dev/postman/data/
data/
# Generated by local-dev/scripts/gen-customer-known-vectors.py — contains
# HMAC hex keys derived from the gitignored fixture + the runtime PII key.
local-dev/scripts/pg-seed-customers-load.sql

# D-6: drift artifact written by tests/test_migrations_integration.py when
# the golden schema diff fails. Operator inspects + cp's over the golden if
# intentional; never committed.
services/gateway/tests/golden/*.actual.sql
