{
  "family": "freightsentry-riskd-migrate",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "${MIGRATION_TASK_EXEC_ROLE_ARN}",
  "taskRoleArn": "arn:aws:iam::${ACCOUNT_ID}:role/freightsentry-riskd-task",
  "runtimePlatform": {
    "operatingSystemFamily": "LINUX",
    "cpuArchitecture": "X86_64"
  },
  "containerDefinitions": [
    {
      "name": "migrate",
      "image": "${IMAGE_URI}",
      "essential": true,
      "command": ["python", "-m", "alembic", "upgrade", "head"],
      "secrets": [
        {
          "name": "DB_MASTER",
          "valueFrom": "arn:aws:secretsmanager:${REGION}:${ACCOUNT_ID}:secret:freightsentry-riskd/DB_MASTER"
        },
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:${REGION}:${ACCOUNT_ID}:secret:freightsentry-riskd/DATABASE_URL"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/freightsentry-riskd",
          "awslogs-region": "${REGION}",
          "awslogs-stream-prefix": "migrate",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}
