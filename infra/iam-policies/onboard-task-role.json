{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "TenantTokenSecretWrite",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:PutSecretValue",
        "secretsmanager:CreateSecret"
      ],
      "Resource": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:freightsentry-riskd/tenants/*"
    }
  ]
}
